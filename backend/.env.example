DVLA_API_KEY=your_dvla_api_key_here

# DVSA MOT History API — OAuth2 credentials from your approval email
DVSA_CLIENT_ID=your_client_id
DVSA_CLIENT_SECRET=your_client_secret
DVSA_API_KEY=your_api_key
DVSA_SCOPE=https://tapi.dvsa.gov.uk/.default
DVSA_TOKEN_URL=https://login.microsoftonline.com/<tenant_id>/oauth2/v2.0/token

ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_HOUR=10
ENVIRONMENT=development
